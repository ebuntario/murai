# PostgreSQL connection string
# Get a free database at https://neon.tech
DATABASE_URL=postgres://user:pass@host/dbname

# Midtrans sandbox credentials
# Get yours at https://dashboard.sandbox.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL for redirects (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
