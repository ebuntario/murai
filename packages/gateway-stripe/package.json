{
	"name": "@murai/gateway-stripe",
	"version": "1.0.0",
	"type": "module",
	"description": "Stripe Checkout payment gateway adapter for murai",
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@murai/core": "workspace:*"
	},
	"engines": {
		"node": ">=22"
	}
}
