{
	"name": "@token-wallet/storage-drizzle",
	"version": "0.0.1",
	"type": "module",
	"description": "Drizzle ORM storage adapter for token-wallet (PostgreSQL, MySQL, SQLite)",
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@token-wallet/core": "workspace:*"
	},
	"peerDependencies": {
		"drizzle-orm": ">=0.30.0"
	}
}
