{
	"name": "token-wallet",
	"version": "0.0.1",
	"type": "module",
	"description": "Lightweight token wallet library for AI/SaaS apps — with Midtrans & Xendit support",
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"sideEffects": false,
	"keywords": [
		"token",
		"wallet",
		"credits",
		"billing",
		"midtrans",
		"xendit",
		"indonesia",
		"ai",
		"saas"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@token-wallet/core": "workspace:*",
		"@token-wallet/gateway-midtrans": "workspace:*",
		"@token-wallet/gateway-xendit": "workspace:*",
		"@token-wallet/storage-drizzle": "workspace:*"
	}
}
